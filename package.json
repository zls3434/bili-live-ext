{
  "name": "bili-live-ext",
  "displayName": "bilibili",
  "description": "在 VSCode 中浏览 B站（bilibili）直播和视频",
  "version": "0.1.0",
  "publisher": "zls3434",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/zls3434/bili-live-ext"
  },
  "engines": {
    "vscode": "^1.88.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:bilibili-main-view"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "bilibili-main-view",
          "name": "bilibili",
          "type": "webview",
          "icon": "media/icon.png"
        }
      ]
    },
    "commands": [
      {
        "command": "bilibili.login",
        "title": "B站扫码登录"
      },
      {
        "command": "bilibili.openVideo",
        "title": "打开视频"
      },
      {
        "command": "bilibili.openLive",
        "title": "打开直播"
      },
      {
        "command": "bilibili.goBack",
        "title": "返回上一页"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "lint": "eslint src --ext ts",
    "pretest": "npm run compile && npm run lint"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "flv.js": "^1.6.2",
    "qrcode": "^1.5.3",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/qrcode": "^1.5.6",
    "@types/vscode": "^1.88.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "@vscode/vsce": "^2.27.0",
    "eslint": "^8.57.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.5",
    "webpack": "^5.92.0",
    "webpack-cli": "^5.1.4"
  }
}
